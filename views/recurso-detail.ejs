<%- include('partials/head-meta', { title, description, canonical }) %>
    <%- include('partials/header') %>

        <main class="main-content">
            <section class="recurso-detail-section">
                <div class="container">
                    <div class="recurso-detail">
                        <header class="recurso-header">
                            <h1 class="recurso-title">
                                <%= recurso.title %>
                            </h1>
                            <p class="recurso-description">
                                <%= recurso.summary %>
                            </p>
                        </header>

                        <div class="recurso-visual">
                            <img loading="lazy" src="<%= recurso.cover %>" alt="<%= recurso.title %>"
                                class="recurso-cover">
                        </div>

                        <% if (recurso.slug==='guia-materiales' ) { %>
                            <!-- Contenido específico para Guía de Materiales Completa -->
                            <div class="recurso-content-detail">
                                <div class="content-section">
                                    <h2>¿Qué es?</h2>
                                    <p>Una guía práctica para elegir materiales con criterio sin tecnicismos. Reúne en
                                        un solo lugar qué preferir y qué evitar por oficio, por qué hacerlo y cómo
                                        aplicarlo en tu día a día.</p>
                                </div>

                                <div class="content-section">
                                    <h2>¿Para quién?</h2>
                                    <ul>
                                        <li><strong>Artesanos y pequeños talleres.</strong></li>
                                        <li><strong>Marcas emergentes de producto físico</strong> (textil, cerámica,
                                            joyería, madera, papel/cartón, velas/cosmética, packaging, etc.).</li>
                                        <li><strong>Diseñadores y makers</strong> que buscan criterios claros y
                                            proveedores fiables.</li>
                                    </ul>
                                </div>

                                <div class="content-section">
                                    <h2>Qué incluye</h2>
                                    <ul>
                                        <li><strong>Criterios por oficio:</strong> qué preferir/evitar y la razón
                                            (impacto, durabilidad, fin de vida, viabilidad).</li>
                                        <li><strong>Fichas de materiales</strong> con pros/contras y usos recomendados.
                                        </li>
                                        <li><strong>Checklist de compra responsable</strong> para revisar en 2–3 minutos
                                            antes de pedir.</li>
                                        <li><strong>Marco legal exprés</strong> para comunicar sin greenwashing.</li>
                                        <li><strong>Errores habituales</strong> y cómo evitarlos.</li>
                                        <li><strong>Plantillas simples:</strong> matriz de decisión y trazabilidad
                                            mínima.</li>
                                        <li><strong>Acceso al Directorio vivo</strong> de proveedores verificados y
                                            recursos que actualizamos de forma continua.</li>
                                    </ul>
                                </div>

                                <div class="content-section">
                                    <h2>Qué te resuelve</h2>
                                    <ul>
                                        <li>Ahorras horas de búsqueda y pruebas fallidas.</li>
                                        <li>Reduces residuos y retrabajos desde el diseño.</li>
                                        <li>Tomas decisiones con criterio y puedes explicarlas a clientes y equipo.</li>
                                        <li>Evitas riesgos por claims ambientales confusos.</li>
                                    </ul>
                                </div>

                                <div class="content-section">
                                    <h2>Formato y actualizaciones</h2>
                                    <p>Descarga en PDF + acceso al Directorio vivo para que tus contactos y recursos no
                                        queden desactualizados.</p>
                                </div>
                            </div>
                            <% } else if (recurso.slug==='circular-express' ) { %>
                                <!-- Contenido específico para Circular Express -->
                                <div class="recurso-content-detail">
                                    <div class="content-section">
                                        <h2>¿Qué es?</h2>
                                        <p>Un auto-diagnóstico breve para medir el nivel de circularidad de tu taller o
                                            marca y decidir dónde actuar primero.</p>
                                    </div>

                                    <div class="content-section">
                                        <h2>¿Para quién?</h2>
                                        <ul>
                                            <li><strong>Artesanos y pequeños talleres.</strong></li>
                                            <li><strong>Marcas emergentes de producto físico.</strong></li>
                                            <li><strong>Cualquier proyecto</strong> que quiera una foto rápida de su
                                                situación y un plan simple para mejorar.</li>
                                        </ul>
                                    </div>

                                    <div class="content-section">
                                        <h2>Qué incluye</h2>
                                        <ul>
                                            <li><strong>Checklist de prácticas clave.</strong></li>
                                            <li><strong>Puntuación rápida por áreas</strong> (materiales, residuos,
                                                diseño, operaciones, comunicación).</li>
                                            <li><strong>Mini-plan de mejora inmediata</strong> con 3–5 acciones
                                                priorizadas.</li>
                                            <li><strong>Consejos prácticos y atajos</strong> para empezar hoy.</li>
                                        </ul>
                                    </div>

                                    <div class="content-section">
                                        <h2>Cómo funciona (3 pasos)</h2>
                                        <ol>
                                            <li><strong>Descarga la guía.</strong></li>
                                            <li><strong>Completa el checklist</strong> (10–15 min).</li>
                                            <li><strong>Revisa tu puntuación</strong> y aplica el mini-plan.</li>
                                        </ol>
                                    </div>

                                    <div class="content-section">
                                        <h2>Qué te llevas</h2>
                                        <ul>
                                            <li>Claridad sobre lo que ya haces bien.</li>
                                            <li>Un orden de prioridades realista para las próximas semanas.</li>
                                            <li>Un lenguaje común para hablar con equipo y clientes.</li>
                                        </ul>
                                    </div>

                                    <div class="content-section">
                                        <h2>Formato y tiempo</h2>
                                        <p>PDF breve y accionable. Se completa en 10–15 minutos.</p>
                                    </div>
                                </div>
                                <% } else if (recurso.slug==='guia-upcycling-artistas' ) { %>
                                    <!-- Contenido específico para Guía Upcycling -->
                                    <div class="recurso-content-detail">
                                        <div class="content-section">
                                            <h2>¿Qué es esta guía?</h2>
                                            <p><strong>Guía Artistas Upcycling + Toolkit Práctico.</strong> 50 páginas
                                                de casos reales, técnicas aplicables y plantillas visuales.</p>
                                            <p>Perfecto para: Marcas artesanales españolas y latinoamericanas que buscan
                                                diferenciarse con circularidad auténtica.</p>
                                        </div>

                                        <div class="content-section">
                                            <h2>¿Qué vas a encontrar dentro?</h2>
                                            <ul>
                                                <li><strong>12 Casos de Artistas Reconocidos:</strong> Vik Muniz,
                                                    Bordalo II, Bernard Pras, Miquel Aparici y más. Con análisis de
                                                    técnicas, materiales y modelo de negocio.</li>
                                                <li><strong>7 Técnicas Aplicables a Pequeña Escala:</strong> Desde
                                                    collage con residuos hasta escultura con chatarra. Paso a paso
                                                    adaptado a talleres artesanales.</li>
                                                <li><strong>30+ Materiales Ideales por Sector:</strong> Textil, madera,
                                                    metal, papel, plástico. Dónde conseguirlos y cómo prepararlos para
                                                    transformación.</li>
                                                <li><strong>Framework de Storytelling Circular:</strong> Cómo comunicar
                                                    tu proceso sin greenwashing. Narrativas auténticas que conectan
                                                    emocionalmente.</li>
                                            </ul>
                                        </div>

                                        <div class="content-section">
                                            <h2>Y eso no es todo... (Bonus Incluido)</h2>
                                            <ul>
                                                <li><strong>Guía de Proveedores Circulares España:</strong> Directorio
                                                    de 20+ proveedores de materiales recuperados en península ibérica
                                                    con contactos directos.</li>
                                                <li><strong>Calculadora de Impacto Ambiental:</strong> Plantilla Excel
                                                    para medir kg CO2 evitados y kg residuos transformados. Comunica tu
                                                    impacto con datos reales.</li>
                                                <li><strong>Checklist Fotografía de Proceso:</strong> 15 momentos clave
                                                    para documentar tu transformación. Storytelling visual que vende.
                                                </li>
                                                <li><strong>15 Plantillas Visuales Editables:</strong> Esquemas
                                                    antes/después, infografías materiales, templates redes sociales para
                                                    mostrar tu proceso circular.</li>
                                            </ul>
                                        </div>

                                        <div class="content-section">
                                            <h2>Con este recurso podrás:</h2>
                                            <ul>
                                                <li>Reducir hasta 60% los costes de tus materiales identificando
                                                    residuos de alto potencial.</li>
                                                <li>Multiplicar x3 el valor percibido de tus productos con narrativas de
                                                    transformación auténticas.</li>
                                                <li>Diferenciarte en mercados saturados con piezas únicas cargadas de
                                                    historia y propósito.</li>
                                                <li>Atraer clientes conscientes dispuestos a pagar más por
                                                    sostenibilidad real y tangible.</li>
                                            </ul>
                                        </div>
                                    </div>
                                    <% } else if (recurso.slug==='5-filtros-residuo-material' ) { %>
                                        <!-- Contenido específico para 5 Filtros: de residuo local a material -->
                                        <div class="recurso-content-detail">
                                            <div class="content-section">
                                                <h2>¿Qué es?</h2>
                                                <p>Un método paso a paso para decidir si un residuo agrícola o industrial cercano a tu taller puede convertirse en material útil para tus piezas. Te ayuda a evaluar oportunidad real antes de invertir tiempo ni dinero.</p>
                                            </div>

                                            <div class="content-section">
                                                <h2>¿Para quién?</h2>
                                                <ul>
                                                    <li><strong>Artesanos y pequeños talleres</strong> que quieren trabajar con materiales locales y circulares.</li>
                                                    <li><strong>Marcas de producto físico</strong> (textil, cerámica, joyería, cosmética, packaging) que buscan diferenciarse con circularidad auténtica.</li>
                                                    <li><strong>Diseñadores y makers</strong> que quieren evaluar residuos sin depender de la intuición.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Qué incluye</h2>
                                                <ul>
                                                    <li><strong>5 filtros secuenciales:</strong> Disponibilidad y cercanía, Compatibilidad técnica, Coste real de transformación, Demanda y narrativa, y Normativa básica.</li>
                                                    <li><strong>Tabla de puntuación</strong> con semáforo verde/amarillo/rojo para cada filtro.</li>
                                                    <li><strong>Regla de decisión clara:</strong> GO (arrancar), PILOTO (probar a pequeña escala) o NO AHORA (descartar sin culpa).</li>
                                                    <li><strong>Ejemplo real aplicado:</strong> hoja de parra de viñedo evaluada con los 5 filtros paso a paso.</li>
                                                    <li><strong>Checklist imprimible</strong> para llevar al campo o al almacén.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Cómo funciona (3 pasos)</h2>
                                                <ol>
                                                    <li><strong>Descarga la guía</strong> e identifica un residuo cercano que te llame la atención.</li>
                                                    <li><strong>Pásalo por los 5 filtros</strong> y puntúa cada uno en la tabla.</li>
                                                    <li><strong>Suma y decide:</strong> GO, PILOTO o NO AHORA. Sin dramas.</li>
                                                </ol>
                                            </div>

                                            <div class="content-section">
                                                <h2>Qué te resuelve</h2>
                                                <ul>
                                                    <li>Dejas de evaluar residuos "a ojo" y usas criterio técnico real.</li>
                                                    <li>Ahorras semanas de pruebas con materiales que no merecían la pena.</li>
                                                    <li>Puedes explicar a clientes y equipo por qué elegiste ese material.</li>
                                                    <li>Conectas tu proyecto con la economía local de forma verificable.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Formato y tiempo</h2>
                                                <p>PDF de 11 páginas, directo al grano. Aplicar los 5 filtros a un residuo lleva menos de 20 minutos.</p>
                                            </div>
                                        </div>
                                    <% } else if (recurso.slug==='plantilla-dpp' ) { %>
                                        <!-- Contenido específico para Plantilla Base DPP -->
                                        <div class="recurso-content-detail">
                                            <div class="content-section">
                                                <h2>¿Qué es?</h2>
                                                <p>Un Pasaporte Digital de Producto (DPP) documenta toda la vida de lo que creas: de dónde vienen tus materiales, cómo los transformas, cuánto dura tu pieza, cómo se repara y qué pasa cuando termina su vida útil. Esta plantilla te lo pone fácil: campos guiados, sin tecnicismos, y un checklist de 30 días para que no se quede en el cajón.</p>
                                            </div>

                                            <div class="content-section">
                                                <h2>¿Para quién?</h2>
                                                <ul>
                                                    <li><strong>Artesanos y pequeños talleres</strong> que quieren documentar sus procesos sin complicarse.</li>
                                                    <li><strong>Marcas emergentes de producto físico</strong> (textil, cerámica, joyería, madera, cuero, cosmética, alimentación artesanal).</li>
                                                    <li><strong>Diseñadores y makers</strong> que necesitan demostrar trazabilidad y circularidad de forma creíble.</li>
                                                    <li><strong>Proyectos que quieren prepararse</strong> para la normativa europea de DPP antes de que sea obligatoria.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Qué incluye</h2>
                                                <ul>
                                                    <li><strong>Plantilla DPP completa</strong> con 9 secciones (identificación, materiales, proveedores, proceso, durabilidad, reparabilidad, fin de vida, claims y control documental) — campos obligatorios marcados para saber por dónde empezar.</li>
                                                    <li><strong>Estructura de carpeta de evidencias</strong> lista para copiar y organizar toda tu documentación por SKU.</li>
                                                    <li><strong>Checklist de implementación en 4 semanas</strong> — tareas concretas semana a semana para no dejarlo a medias.</li>
                                                    <li><strong>Criterio "DPP-ready"</strong> — 5 puntos para saber cuándo un producto está listo para comercializar con confianza.</li>
                                                    <li><strong>Guía anti-greenwashing</strong> con plantilla de claims verificables: qué puedes decir, qué evidencia necesitas y qué evitar.</li>
                                                    <li><strong>Listado de errores comunes</strong> para no caer en los fallos típicos de documentación.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Qué te resuelve</h2>
                                                <ul>
                                                    <li>Dejas de improvisar la documentación de tus productos y tienes un sistema claro desde el primer día.</li>
                                                    <li>Puedes responder con datos a cualquier pregunta sobre trazabilidad, materiales o circularidad.</li>
                                                    <li>Eliminas el riesgo de hacer claims que no puedas demostrar (adiós, greenwashing accidental).</li>
                                                    <li>Te adelantas a la normativa europea de DPP con una base sólida y escalable.</li>
                                                </ul>
                                            </div>

                                            <div class="content-section">
                                                <h2>Formato y actualizaciones</h2>
                                                <p>PDF descargable. Plantilla duplicable por cada producto/SKU. Incluye todos los campos, checklists y plantillas de claims listos para rellenar.</p>
                                            </div>
                                        </div>
                                    <% } %>

                                        <!-- FORMULARIO TALLY con parámetros optimizados -->
                                        <section class="recurso-cta">
                                            <div class="cta-container">
                                                <h3>Completa el formulario para recibir el recurso</h3>
                                                <p>Descarga inmediata después de completar los datos</p>

                                                <!-- Constante base con parámetros del servidor -->
                                                <% const
                                                    base=`https://tally.so/embed/${recurso.form_tally_id}?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1&resource_id=${recurso.slug}&source=web`;
                                                    %>

                                                    <!-- Embed de Tally -->
                                                    <div id="tally-embed" class="tally-form-container"
                                                        aria-live="polite">
                                                        <iframe data-tally-src="<%= base %>" loading="lazy" width="100%"
                                                            height="500" frameborder="0" marginheight="0"
                                                            marginwidth="0" title="<%= recurso.title %>"></iframe>
                                                    </div>
                                                    <script defer>
                                                        (function () {
                                                            var s = document.createElement('script');
                                                            s.src = 'https://tally.so/widgets/embed.js';
                                                            s.onload = function () {
                                                                if (window.Tally) {
                                                                    Tally.loadEmbeds();

                                                                    // Script optimizado: solo page_url, UTMs se heredan automáticamente
                                                                    window.addEventListener('message', function (e) {
                                                                        if (e.data.type === 'tally-form-submitted') {
                                                                            const url = new URL(window.location.href);
                                                                            const params = new URLSearchParams();
                                                                            params.set('page_url', url.href);
                                                                            // UTMs se heredan de window.location.search tal cual

                                                                            // Redirigir a la página de gracias
                                                                            window.location.href = `/gracias/<%= recurso.slug %>?${params.toString()}`;
                                                                        }
                                                                    });
                                                                }
                                                            };
                                                            document.body.appendChild(s);
                                                        })();
                                                    </script>

                                                    <!-- Información adicional -->
                                                    <div class="form-info">
                                                        <p><small>🔒 Tus datos están seguros. Solo los usamos para
                                                                enviarte el recurso y contenido relacionado
                                                                ocasionalmente.</small></p>
                                                    </div>
                                            </div>
                                        </section>
                    </div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>

            <script src="/assets/js/script.js"></script>
            </body>

            </html>
