    <script>
      (function(){
        var KEY='oc_blog_popup_lujo_dismissed';
        try{ if(sessionStorage.getItem(KEY)) return; }catch(e){}
        var el=document.getElementById('blog-popup');
        var btn=document.getElementById('blog-popup-close');
        if(!el||!btn) return;
        function dismiss(){ el.classList.remove('is-visible'); el.setAttribute('aria-hidden','true'); try{sessionStorage.setItem(KEY,'1');}catch(e){} }
        btn.addEventListener('click',function(ev){ ev.preventDefault(); ev.stopPropagation(); dismiss(); });
        el.querySelector('.blog-popup__link').addEventListener('click',function(){ try{sessionStorage.setItem(KEY,'1');}catch(e){} });
        setTimeout(function(){ el.classList.add('is-visible'); el.setAttribute('aria-hidden','false'); }, 4000);
      })();
    </script>
