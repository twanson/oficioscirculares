<script>
  // Test A/B del hero: 'slides' (Ken Burns) vs 'video' (montaje multi-oficio).
  // 50/50 persistido en localStorage; forzable con ?hero=video / ?hero=slides.
  let heroVar = new URLSearchParams(location.search).get('hero');
  if (heroVar !== 'video' && heroVar !== 'slides') { try { heroVar = localStorage.getItem('ocClubHeroVar'); } catch(e){} }
  if (heroVar !== 'video' && heroVar !== 'slides') heroVar = Math.random() < 0.5 ? 'video' : 'slides';
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) heroVar = 'slides';
  try { localStorage.setItem('ocClubHeroVar', heroVar); } catch(e){}
  if (heroVar === 'video') {
    const vid = document.getElementById('heroVideo');
    const src = vid.querySelector('source');
    src.src = src.dataset.src; vid.load();
    document.getElementById('heroSlides').style.display = 'none';
    vid.style.display = 'block';
    vid.play().catch(function(){});
  }
  window.dataLayer && window.dataLayer.push({event: 'hero_variant', hero_variant: heroVar});

  // Scrollytelling: la foto sticky cambia con cada beat
  const fotos = document.querySelectorAll('#probSticky img');
  const pies = ['El domingo después de la feria', 'El oficio que no se ve, no se vende', 'La demanda existe. Faltas tú'];
  const pie = document.getElementById('probPie');
  const beatObserver = new IntersectionObserver((entries) => {
    entries.forEach(en => {
      if (en.isIntersecting) {
        const i = parseInt(en.target.dataset.foto, 10);
        fotos.forEach((f, j) => f.classList.toggle('activa', i === j));
        if (pies[i]) pie.textContent = pies[i];
      }
    });
  }, {threshold: 0.45});
  document.querySelectorAll('.beat').forEach(b => beatObserver.observe(b));

  // Reveal on scroll
  const rev = new IntersectionObserver((entries) => {
    entries.forEach(en => {
      if (en.isIntersecting) { en.target.classList.add('in'); rev.unobserve(en.target); }
    });
  }, {threshold: 0.12});
  document.querySelectorAll('.reveal').forEach(el => rev.observe(el));
</script>

