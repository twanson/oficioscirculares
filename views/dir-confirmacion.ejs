<%-
  include('partials/head-meta', {
    title: 'Confirma tu acceso — Directorio | Oficios Circulares',
    description: 'Te hemos enviado un email con tu enlace de acceso al Directorio.',
    canonical: '/dir/confirmacion',
    noindex: typeof noindex !== 'undefined' ? noindex : true
  })
%>
  <%- include('partials/header') %>
  <main class="main-content" style="padding: 100px 0; background: #fbf9f8;">
    <div class="container" style="max-width: 560px; margin: 0 auto; padding: 0 24px; text-align: center;">
      <div style="font-size: 3.5rem; margin-bottom: 1.5rem;">📬</div>
      <h1 style="font-family: 'Newsreader', serif; font-size: clamp(2rem, 5vw, 2.4rem); font-weight: 700; color: #023429; line-height: 1.15; margin-bottom: 1rem;">Revisa tu email</h1>
      <p style="font-family: 'Manrope', sans-serif; font-size: 1.05rem; color: #023429; opacity: 0.7; line-height: 1.6; margin-bottom: 1.5rem;">Te hemos enviado un enlace de acceso al Directorio. Si no lo ves, revisa también la carpeta de spam.</p>
      <% if (q && q.email) { %>
        <p style="font-family: 'Manrope', sans-serif; font-size: 0.9rem; color: #023429; opacity: 0.5; margin-bottom: 1.5rem;">Lo enviamos a: <strong><%= q.email %></strong></p>
      <% } %>
      <p style="margin-top: 2rem;">
        <a href="/" style="display: inline-block; background: #023429; color: white; padding: 12px 28px; border-radius: 8px; text-decoration: none; font-family: 'Manrope', sans-serif; font-weight: 600; font-size: 0.95rem; transition: background 0.25s ease;">Volver al inicio</a>
      </p>
    </div>
  </main>
</body>
</html>