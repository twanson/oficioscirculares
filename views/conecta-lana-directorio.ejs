<%- include('partials/head-meta', {
    title: 'Directorio · Conecta Lana — quién tiene, transforma y busca lana en España | Oficios Circulares',
    description: 'El directorio abierto de la lana española: ganaderos que ofrecen lana, talleres que la transforman y artesanas que la buscan. Apúntate gratis y te conectamos.',
    canonical: '/conecta-lana/directorio',
    ogImage: 'https://www.oficioscirculares.com/assets/images/conecta-cover.jpg',
    ogImageAlt: 'Directorio de Conecta Lana — Oficios Circulares'
}) %>

<%
  const interesar = (nombre) => 'https://tally.so/r/zxg9Zq?proyecto=' + encodeURIComponent(nombre || '') + '&utm_source=conecta-lana&utm_medium=directorio&utm_content=ficha';
  const pin = '<svg class="cld-pin" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>';
  // B4 (jul 2026): filtros — opciones de CCAA a partir de los datos reales
  const ccaaSet = new Set();
  ['tengo', 'transformo', 'busco'].forEach(function(k){ (grouped[k] || []).forEach(function(e){
    if (e.ccaa && e.ccaa !== 'Toda España' && e.ccaa !== 'Varias zonas') ccaaSet.add(e.ccaa);
  }); });
  const ccaaList = Array.from(ccaaSet).sort(function(a, b){ return a.localeCompare(b, 'es'); });
  // atributos de filtrado por ficha
  const q = (s) => String(s || '').replace(/"/g, '&quot;');
  const attrs = (e) => 'data-ccaa="' + q(e.ccaa) + '" data-uso="' + q(e.uso) + '" data-estado="' + q(e.estado_lana) + '" data-search="' + q([e.nombre, e.zona, e.provincia, e.raza_o_busca, e.para_que, e.servicios || ''].join(' ')) + '"';
  // inicial para el avatar de cada ficha
  const inicial = (n) => String(n || '?').trim().charAt(0).toUpperCase();
  // kg totales ofrecidos (para la píldora del hero)
  let kgTotal = 0;
  (grouped.tengo || []).forEach(function(e){ const k = parseFloat(e.kg); if (k > 0) kgTotal += k; });
  const kgFmt = kgTotal >= 1000 ? (Math.round(kgTotal / 1000) + '.000') : String(Math.round(kgTotal));
  // iconos de sección (trazo, mismo estilo que el pin)
  const icoLana = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="8.5"/><path d="M4 10c5-3 11-3 16 0M4 14c5 3 11 3 16 0M12 3.5c-3 5-3 12 0 17M12 3.5c3 5 3 12 0 17"/></svg>';
  const icoTaller = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 4h10v5a5 5 0 0 1-10 0V4Z"/><path d="M7 6H4.5M19.5 6H17M9.5 14.5 8 20.5M14.5 14.5 16 20.5M8 20.5h8"/></svg>';
  const icoBusca = '<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><circle cx="10.5" cy="10.5" r="6.5"/><path d="m15.5 15.5 5 5"/></svg>';
%>

<style>
/* ===================================================================
   DIRECTORIO CONECTA LANA — público. Estilos scoped bajo .cld
   DS v2 OC: verde #023429 · terracota #934a1c · oro #c98a3f · crema
   Secciones apiladas a lo ancho, cada una con su rejilla de fichas.
   =================================================================== */
body { padding-top: 0; margin: 0; }
.cld{
  --verde:#023429;--verde-hoja:#1F4B3F;--verde-medio:#3E7C59;
  --oro:#f6c98a;--oro-acento:#c98a3f;--terracota:#934a1c;
  --crema:#f4efe6;--arena:#ece0cb;--on:#1C1E1B;--on-var:#5d5746;
  --f-head:'Newsreader',Georgia,serif;--f-body:'Manrope',system-ui,sans-serif;--f-ui:'Nunito',sans-serif;
  font-family:var(--f-body);color:var(--on);background:var(--crema);line-height:1.55;-webkit-font-smoothing:antialiased;min-height:100vh;
}
.cld a{text-decoration:none}

/* HERO — foto de dehesa con velo verde (B4 estética) */
.cld-hero{position:relative;background:linear-gradient(160deg,rgba(4,32,24,.93) 0%,rgba(2,52,41,.88) 70%),url('/assets/images/conecta-lana-poster.jpg') center 35%/cover no-repeat;padding:52px 46px 60px}
.cld-hero::after{content:"";position:absolute;inset:auto 0 0 0;height:26px;background:linear-gradient(to top,var(--crema),transparent)}
.cld-stats{display:flex;flex-wrap:wrap;gap:10px;margin-top:22px}
.cld-stat{display:inline-flex;align-items:baseline;gap:7px;background:rgba(251,246,236,.08);border:1px solid rgba(246,201,138,.35);border-radius:100px;padding:8px 16px;color:rgba(251,246,236,.9);font-family:var(--f-ui);font-size:.86rem;font-weight:600;backdrop-filter:blur(2px)}
.cld-stat b{font-family:var(--f-head);font-size:1.25rem;font-weight:700;color:var(--oro)}
.cld-hero-in{max-width:1180px;margin:0 auto}
.cld-back{display:inline-block;color:rgba(246,201,138,.92);font-family:var(--f-ui);font-weight:700;font-size:.84rem;margin-bottom:18px;transition:opacity .2s ease}
.cld-back:hover{opacity:.7}
.cld-ey{display:block;color:var(--oro);font-family:var(--f-ui);font-weight:800;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;margin-bottom:8px}
.cld-hero h1{font-family:var(--f-head);font-size:clamp(2rem,4.4vw,3rem);font-weight:600;color:#fff;line-height:1.08;letter-spacing:-.01em;margin:0 0 14px}
.cld-hero h1 em{font-style:italic;color:var(--oro)}
.cld-sub{color:rgba(251,246,236,.82);font-size:clamp(1rem,1.5vw,1.12rem);line-height:1.55;max-width:660px;margin:0}

/* CUERPO — secciones apiladas (full-width) */
.cld-wrap{max-width:1180px;margin:0 auto;padding:34px 46px 60px}
.cld-sec{margin-bottom:46px}
.cld-sec:last-of-type{margin-bottom:0}
.cld-sechead{display:flex;justify-content:space-between;align-items:flex-end;gap:16px;padding-bottom:12px;margin-bottom:22px;border-bottom:3px solid var(--verde)}
.cld-st h2{font-family:var(--f-head);font-size:clamp(1.4rem,2.4vw,1.7rem);font-weight:700;color:var(--verde);margin:0 0 2px;line-height:1.1}
.cld-st span{font-size:.92rem;color:var(--on-var)}
.cld-count{flex:0 0 auto;font-family:var(--f-ui);font-weight:800;font-size:.84rem;color:var(--verde);background:rgba(2,52,41,.07);padding:5px 13px;border-radius:100px;white-space:nowrap}
.cld-sec--transformo .cld-sechead{border-bottom-color:var(--terracota)}
.cld-sec--transformo .cld-count{color:var(--terracota);background:rgba(147,74,28,.1)}
.cld-sec--busco .cld-sechead{border-bottom-color:var(--oro-acento)}
.cld-sec--busco .cld-count{color:#9a6a1f;background:rgba(201,138,63,.15)}

/* REJILLA de fichas: 3-4 por fila en escritorio, 2 en tablet, 1 en móvil */
.cld-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(290px,1fr));gap:16px;align-items:stretch}

/* FICHAS (altura igualada: botón siempre abajo) */
.cld-card{background:#fff;border:1px solid rgba(2,52,41,.07);border-top:3px solid var(--verde);border-radius:16px;padding:20px 22px;box-shadow:0 8px 22px rgba(2,52,41,.06);display:flex;flex-direction:column;transition:transform .18s ease,box-shadow .18s ease}
.cld-card:hover{transform:translateY(-3px);box-shadow:0 16px 34px rgba(2,52,41,.13)}
.cld-sec--transformo .cld-card{border-top-color:var(--terracota)}
.cld-sec--busco .cld-card{border-top-color:var(--oro-acento)}
.cld-cardhead{display:flex;align-items:center;gap:11px;margin:0 0 6px}
.cld-avatar{flex:0 0 auto;width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-family:var(--f-head);font-size:1.15rem;font-weight:700;background:rgba(2,52,41,.08);color:var(--verde)}
.cld-sec--transformo .cld-avatar{background:rgba(147,74,28,.1);color:var(--terracota)}
.cld-sec--busco .cld-avatar{background:rgba(201,138,63,.16);color:#9a6a1f}
.cld-card h3{font-family:var(--f-head);font-size:1.26rem;font-weight:700;color:var(--verde);margin:0;line-height:1.15}
.cld-ico{display:inline-flex;vertical-align:-3px;margin-right:8px;color:var(--verde);opacity:.85}
.cld-sec--transformo .cld-ico{color:var(--terracota)}
.cld-sec--busco .cld-ico{color:#9a6a1f}
.cld-zona{display:flex;align-items:center;gap:5px;color:var(--verde-medio);font-size:.9rem;margin-bottom:11px}
.cld-zona .cld-pin{flex:0 0 auto;opacity:.85}
.cld-line{font-size:.97rem;color:var(--on);margin:0 0 11px;line-height:1.45;display:-webkit-box;-webkit-line-clamp:4;line-clamp:4;-webkit-box-orient:vertical;overflow:hidden}
.cld-line strong{color:var(--verde);font-weight:700}
.cld-note{font-size:.89rem;color:var(--on-var);font-style:italic;margin:0 0 12px}
.cld-desc{font-size:.92rem;color:var(--on-var);line-height:1.5;margin:0 0 12px;display:-webkit-box;-webkit-line-clamp:3;line-clamp:3;-webkit-box-orient:vertical;overflow:hidden}
/* "…ver más" — desplegar textos truncados */
.cld-line.is-expanded,.cld-desc.is-expanded{display:block;-webkit-line-clamp:unset;line-clamp:unset;overflow:visible}
.cld-more{align-self:flex-start;display:inline-block;background:none;border:0;padding:0;margin:-6px 0 12px;color:var(--verde);font-family:var(--f-ui);font-size:.88rem;font-weight:600;line-height:1.3;text-align:left;cursor:pointer}
.cld-more:hover{text-decoration:underline}
.cld-more:focus-visible{outline:2px solid var(--verde);outline-offset:2px;border-radius:3px}
.cld-chips{display:flex;flex-wrap:wrap;gap:8px;margin:0 0 14px}
.cld-chip{background:var(--arena);color:#8a5524;font-size:.8rem;font-weight:700;padding:5px 13px;border-radius:100px}
.cld-btn{margin-top:auto;align-self:flex-start;display:inline-block;background:var(--verde);color:#fff;font-family:var(--f-ui);font-weight:800;font-size:.92rem;padding:11px 20px;border-radius:100px;transition:background .2s ease,transform .2s ease}
.cld-btn:hover{background:var(--verde-hoja);transform:translateY(-1px)}

/* Ficha fantasma (capta altas) — primera de cada sección */
.cld-card--ghost{background:rgba(255,255,255,.5);border:1px dashed rgba(2,52,41,.32);box-shadow:none}
.cld-card--ghost h3{color:var(--verde)}
.cld-card--ghost .cld-zona{opacity:.55}
.cld-sec--transformo .cld-card--ghost{border-color:rgba(147,74,28,.42)}
.cld-sec--transformo .cld-card--ghost h3{color:var(--terracota)}
.cld-sec--busco .cld-card--ghost{border-color:rgba(201,138,63,.5)}
.cld-sec--busco .cld-card--ghost h3{color:#9a6a1f}

.cld-foot{max-width:760px;margin:44px auto 0;text-align:center;color:var(--on-var);font-size:.88rem;line-height:1.5}

/* B4 — BARRA DE FILTROS */
.cld-filters{position:sticky;top:0;z-index:20;background:var(--crema);border-bottom:1px solid rgba(2,52,41,.12);padding:14px 0;margin-bottom:26px}
.cld-filters-in{display:flex;flex-wrap:wrap;gap:10px;align-items:center}
.cld-filters label{font-family:var(--f-ui);font-weight:700;font-size:.78rem;color:var(--verde);display:block;margin:0 0 3px}
.cld-f{display:flex;flex-direction:column}
.cld-filters input[type="search"],.cld-filters select{font-family:var(--f-body);font-size:.92rem;color:var(--on);background:#fff;border:1px solid rgba(2,52,41,.18);border-radius:10px;padding:9px 12px;min-width:170px}
.cld-filters input[type="search"]{min-width:220px;flex:1}
.cld-filters input:focus,.cld-filters select:focus{outline:2px solid var(--verde);outline-offset:1px}
.cld-clear{align-self:flex-end;background:none;border:1px solid rgba(2,52,41,.25);color:var(--verde);font-family:var(--f-ui);font-weight:700;font-size:.84rem;border-radius:100px;padding:9px 16px;cursor:pointer;transition:background .2s ease}
.cld-clear:hover{background:rgba(2,52,41,.06)}
.cld-fhint{width:100%;font-size:.8rem;color:var(--on-var);margin:2px 0 0}

/* B4 — badge "Nuevo" */
.cld-new{display:inline-block;vertical-align:middle;margin-left:8px;background:var(--verde-medio);color:#fff;font-family:var(--f-ui);font-weight:800;font-size:.66rem;letter-spacing:.08em;text-transform:uppercase;padding:3px 9px;border-radius:100px}

/* B4 — sin resultados */
.cld-empty{display:none;background:rgba(255,255,255,.6);border:1px dashed rgba(2,52,41,.25);border-radius:14px;padding:18px 20px;color:var(--on-var);font-size:.94rem;grid-column:1/-1}
.cld-sec.is-empty .cld-empty{display:block}

@media(max-width:600px){
  .cld-filters{padding:12px 0}
  .cld-filters input[type="search"],.cld-filters select{min-width:100%;width:100%}
  .cld-f{width:100%}
  .cld-clear{width:100%;align-self:stretch}
}

@media(max-width:600px){
  .cld-hero{padding:36px 22px 44px}
  .cld-wrap{padding:28px 18px 48px}
  .cld-grid{grid-template-columns:1fr;gap:14px}
  .cld-sec{margin-bottom:38px}
}
</style>

<main class="cld">
  <header class="cld-hero">
    <div class="cld-hero-in">
      <a class="cld-back" href="/conecta-lana">← Volver a Conecta Lana</a>
      <span class="cld-ey">Un proyecto de Oficios Circulares</span>
      <h1>Directorio · Conecta <em>Lana</em></h1>
      <p class="cld-sub">Quién tiene lana, quién la transforma y quién la busca, en España. Apúntate gratis y te conectamos. Pulsa «Me interesa» y os presentamos.</p>
      <div class="cld-stats">
        <span class="cld-stat"><b><%= grouped.tengo.length %></b> ofrecen lana</span>
        <span class="cld-stat"><b><%= grouped.transformo.length %></b> la transforman</span>
        <span class="cld-stat"><b><%= grouped.busco.length %></b> la buscan</span>
        <% if (kgTotal > 0) { %><span class="cld-stat"><b>≈<%= kgFmt %> kg</b> buscando salida</span><% } %>
      </div>
    </div>
  </header>

  <div class="cld-wrap">

    <!-- B4: FILTROS -->
    <div class="cld-filters">
      <div class="cld-filters-in">
        <div class="cld-f" style="flex:1;min-width:220px">
          <label for="cld-q">Buscar</label>
          <input type="search" id="cld-q" placeholder="Raza, zona, nombre… (p. ej. merina, Galicia)" autocomplete="off">
        </div>
        <div class="cld-f">
          <label for="cld-ccaa">Comunidad autónoma</label>
          <select id="cld-ccaa">
            <option value="">Todas</option>
            <% ccaaList.forEach(function(c){ %><option value="<%= c %>"><%= c %></option><% }) %>
          </select>
        </div>
        <div class="cld-f">
          <label for="cld-uso">Uso (buscan lana)</label>
          <select id="cld-uso">
            <option value="">Todos</option>
            <option value="textil">Producto textil</option>
            <option value="agrícola">Acolchado / agrícola</option>
            <option value="I+D">I+D / investigación</option>
          </select>
        </div>
        <div class="cld-f">
          <label for="cld-estado">Estado de la lana (tienen)</label>
          <select id="cld-estado">
            <option value="">Todos</option>
            <option value="vellon sucio">Vellón sucio (sin lavar)</option>
            <option value="lavada">Lavada</option>
            <option value="cardada">Cardada</option>
            <option value="hilada">Hilada</option>
          </select>
        </div>
        <button type="button" class="cld-clear" id="cld-clear">Limpiar filtros</button>
        <p class="cld-fhint">Quien sirve a «Toda España» aparece también al filtrar por tu comunidad.</p>
      </div>
    </div>

    <!-- TIENEN LANA -->
    <section class="cld-sec cld-sec--tengo">
      <div class="cld-sechead">
        <div class="cld-st"><h2><span class="cld-ico"><%- icoLana %></span>Tienen lana</h2><span>Ganaderos y productores</span></div>
        <span class="cld-count"><%= grouped.tengo.length %> en el directorio</span>
      </div>
      <div class="cld-grid">
        <article class="cld-card cld-card--ghost">
          <h3>¿Tienes lana?</h3>
          <div class="cld-zona"><%- pin %><span>—</span></div>
          <p class="cld-line"><strong>Ofrece:</strong> tu raza, cantidad y zona…</p>
          <p class="cld-note">Aparece en el directorio</p>
          <a class="cld-btn" href="https://tally.so/r/GxkleO?utm_source=conecta-lana&utm_medium=directorio&utm_content=placeholder-tengo" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <div class="cld-empty">Nadie encaja con esos filtros en esta sección — prueba a quitar alguno.</div>
        <% grouped.tengo.forEach(function(e){ %>
        <article class="cld-card" <%- attrs(e) %>>
          <div class="cld-cardhead"><span class="cld-avatar" aria-hidden="true"><%= inicial(e.nombre) %></span><h3><%= e.nombre %><% if (e.esNuevo) { %> <span class="cld-new">Nuevo</span><% } %></h3></div>
          <% if (e.zona) { %><div class="cld-zona"><%- pin %><span><%= e.zona %></span></div><% } %>
          <% var cant = (e.cantidad || '').trim(); var cantTxt = cant ? (/[a-zA-Z]/.test(cant) ? cant : cant + ' kg') : ''; var ofrece = [ cantTxt, e.raza_o_busca ].filter(Boolean).join(' · '); %>
          <% if (ofrece) { %><p class="cld-line"><strong>Ofrece:</strong> <%= ofrece %></p><% } %>
          <% if (e.estado_lana) { %><div class="cld-chips"><span class="cld-chip"><%= e.estado_lana %></span></div><% } %>
          <a class="cld-btn" href="<%= interesar(e.nombre) %>" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <% }) %>
      </div>
    </section>

    <!-- TRANSFORMAN LANA -->
    <section class="cld-sec cld-sec--transformo">
      <div class="cld-sechead">
        <div class="cld-st"><h2><span class="cld-ico"><%- icoTaller %></span>Transforman lana</h2><span>Lavado · hilado · fieltro · prenda</span></div>
        <span class="cld-count"><%= grouped.transformo.length %> en el directorio</span>
      </div>
      <div class="cld-grid">
        <article class="cld-card cld-card--ghost">
          <h3>Tu taller aquí</h3>
          <div class="cld-zona"><%- pin %><span>—</span></div>
          <p class="cld-line"><strong>Servicios:</strong> Lavado · Fieltrado · Teñido…</p>
          <p class="cld-note">¿Transformas lana? Aparece en el directorio</p>
          <a class="cld-btn" href="https://tally.so/r/xXgWMr?utm_source=conecta-lana&utm_medium=directorio&utm_content=tu-taller" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <div class="cld-empty">Nadie encaja con esos filtros en esta sección — prueba a quitar alguno.</div>
        <% grouped.transformo.forEach(function(e){ %>
        <article class="cld-card" <%- attrs(e) %>>
          <div class="cld-cardhead"><span class="cld-avatar" aria-hidden="true"><%= inicial(e.nombre) %></span><h3><%= e.nombre %><% if (e.esNuevo) { %> <span class="cld-new">Nuevo</span><% } %></h3></div>
          <% if (e.zona) { %><div class="cld-zona"><%- pin %><span><%= e.zona %></span></div><% } %>
          <% if (e.servicios) { %><p class="cld-line"><strong>Servicios:</strong> <%= e.servicios %></p><% } %>
          <% if (e.trabajaTerceros) { %><p class="cld-note">Trabajan lana de terceros<%= e.tercerosExtra ? (' · ' + e.tercerosExtra) : '' %></p><% } %>
          <% if (e.raza_o_busca) { %><p class="cld-line"><strong>Trabaja con:</strong> <%= e.raza_o_busca %></p><% } %>
          <% if (e.cantidad) { %><p class="cld-line"><strong>Capacidad:</strong> <%= e.cantidad %></p><% } %>
          <% if (e.descripcion) { %><p class="cld-desc"><%= e.descripcion %></p><% } %>
          <a class="cld-btn" href="<%= interesar(e.nombre) %>" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <% }) %>
      </div>
    </section>

    <!-- BUSCAN LANA -->
    <section class="cld-sec cld-sec--busco">
      <div class="cld-sechead">
        <div class="cld-st"><h2><span class="cld-ico"><%- icoBusca %></span>Buscan lana</h2><span>Artesanas · agricultores · I+D</span></div>
        <span class="cld-count"><%= grouped.busco.length %> en el directorio</span>
      </div>
      <div class="cld-grid">
        <article class="cld-card cld-card--ghost">
          <h3>¿Buscas lana?</h3>
          <div class="cld-zona"><%- pin %><span>—</span></div>
          <p class="cld-line"><strong>Busca:</strong> la lana que necesitas…</p>
          <p class="cld-note">Aparece en el directorio</p>
          <a class="cld-btn" href="https://tally.so/r/ODrGQM?utm_source=conecta-lana&utm_medium=directorio&utm_content=placeholder-busco" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <div class="cld-empty">Nadie encaja con esos filtros en esta sección — prueba a quitar alguno.</div>
        <% grouped.busco.forEach(function(e){ %>
        <article class="cld-card" <%- attrs(e) %>>
          <div class="cld-cardhead"><span class="cld-avatar" aria-hidden="true"><%= inicial(e.nombre) %></span><h3><%= e.nombre %><% if (e.esNuevo) { %> <span class="cld-new">Nuevo</span><% } %></h3></div>
          <% if (e.zona) { %><div class="cld-zona"><%- pin %><span><%= e.zona %></span></div><% } %>
          <% var cantB = (e.cantidad || '').trim(); var cantBTxt = cantB ? (/[a-zA-Z]/.test(cantB) ? cantB : cantB + ' kg') : ''; var busca = [ cantBTxt, e.raza_o_busca ].filter(Boolean).join(' · '); %>
          <% if (busca) { %><p class="cld-line"><strong>Busca:</strong> <%= busca %></p><% } %>
          <% if (e.para_que) { %><div class="cld-chips"><span class="cld-chip"><%= e.para_que %></span></div><% } %>
          <a class="cld-btn" href="<%= interesar(e.nombre) %>" target="_blank" rel="noopener">Me interesa →</a>
        </article>
        <% }) %>
      </div>
    </section>

    <p class="cld-foot">Solo aparecen quienes han aceptado figurar en el directorio público · Los contactos los gestiona Oficios Circulares.</p>
  </div>
</main>

<script>
/* B4 — Filtros del directorio (cliente, sin dependencias). */
(function () {
  var q = document.getElementById('cld-q');
  var selCcaa = document.getElementById('cld-ccaa');
  var selUso = document.getElementById('cld-uso');
  var selEstado = document.getElementById('cld-estado');
  var btnClear = document.getElementById('cld-clear');
  if (!q || !selCcaa) return;

  function deacc(s) {
    return String(s || '').toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
  }

  function apply() {
    var term = deacc(q.value.trim());
    var ccaa = selCcaa.value;
    var uso = selUso.value;
    var estado = deacc(selEstado.value);
    document.querySelectorAll('.cld-sec').forEach(function (sec) {
      var esBusco = sec.classList.contains('cld-sec--busco');
      var esTengo = sec.classList.contains('cld-sec--tengo');
      var visibles = 0;
      sec.querySelectorAll('.cld-card:not(.cld-card--ghost)').forEach(function (card) {
        var show = true;
        var cardCcaa = card.getAttribute('data-ccaa') || '';
        if (ccaa && !(cardCcaa === ccaa || cardCcaa === 'Toda España' || cardCcaa === 'Varias zonas')) show = false;
        if (uso && esBusco && (card.getAttribute('data-uso') || '') !== uso) show = false;
        if (estado && esTengo && deacc(card.getAttribute('data-estado')).indexOf(estado) === -1) show = false;
        if (term && deacc(card.getAttribute('data-search')).indexOf(term) === -1) show = false;
        card.style.display = show ? '' : 'none';
        if (show) visibles++;
      });
      var count = sec.querySelector('.cld-count');
      if (count) count.textContent = visibles + ' en el directorio';
      sec.classList.toggle('is-empty', visibles === 0);
    });
  }

  var t;
  q.addEventListener('input', function () { clearTimeout(t); t = setTimeout(apply, 150); });
  [selCcaa, selUso, selEstado].forEach(function (el) { el.addEventListener('change', apply); });
  btnClear.addEventListener('click', function () {
    q.value = ''; selCcaa.value = ''; selUso.value = ''; selEstado.value = '';
    apply();
  });
})();
</script>

<script>
/* Directorio — "…ver más"/"ver menos" en los textos que se truncan con line-clamp. */
(function () {
  var SEL = '.cld-card:not(.cld-card--ghost) .cld-line, .cld-card:not(.cld-card--ghost) .cld-desc';
  function isTruncated(el) { return el.scrollHeight - el.clientHeight > 4; }
  function ensureToggle(el) {
    if (el.classList.contains('is-expanded')) return; // expandido por el usuario: respetar
    var next = el.nextElementSibling;
    var hasBtn = !!(next && next.classList && next.classList.contains('cld-more'));
    if (isTruncated(el)) {
      if (hasBtn) return;
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'cld-more';
      btn.textContent = '…ver más';
      btn.setAttribute('aria-expanded', 'false');
      btn.addEventListener('click', function () {
        var open = el.classList.toggle('is-expanded');
        btn.textContent = open ? 'ver menos' : '…ver más';
        btn.setAttribute('aria-expanded', open ? 'true' : 'false');
      });
      el.insertAdjacentElement('afterend', btn);
    } else if (hasBtn) {
      next.remove(); // dejó de truncarse (p. ej. al ensanchar) y está contraído → quitar enlace
    }
  }
  function run() {
    var els = document.querySelectorAll(SEL);
    for (var i = 0; i < els.length; i++) ensureToggle(els[i]);
  }
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', run);
  else run();
  if (document.fonts && document.fonts.ready) document.fonts.ready.then(run);
  var t;
  window.addEventListener('resize', function () { clearTimeout(t); t = setTimeout(run, 200); });
})();
</script>

</body>
</html>
