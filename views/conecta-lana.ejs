  --f-head:'Newsreader',Georgia,serif;--f-body:'Manrope',sans-serif;--f-ui:'Nunito',sans-serif;
  font-family:var(--f-body);color:var(--on);line-height:1.6;-webkit-font-smoothing:antialiased;background:var(--surface);
}
.cl-landing h1,.cl-landing h2,.cl-landing h3,.cl-landing h4,.cl-landing p{margin:0}
.cl-landing a{text-decoration:none;color:inherit}

/* NAV (transparente sobre el hero) */
.cl-nav{position:absolute;top:0;left:0;right:0;z-index:30;display:flex;align-items:center;justify-content:space-between;padding:20px 46px}
.cl-nav .cl-brand{display:flex;align-items:center;gap:12px}
.cl-nav .cl-brand img{height:50px;width:auto}
.cl-nav .cl-brand span{color:#fff;font-family:var(--f-head);font-size:1.4rem;font-weight:500;text-shadow:0 1px 10px rgba(0,0,0,.35)}
.cl-nav .cl-links{display:flex;gap:24px;font-weight:600;font-size:.88rem;color:#fff}
.cl-nav .cl-links a{text-shadow:0 1px 8px rgba(0,0,0,.4);transition:opacity .2s ease}
.cl-nav .cl-links a:hover{opacity:.74}
@media(max-width:860px){.cl-nav .cl-links,.cl-nav .cl-brand span{display:none}}

/* HERO con vídeo + crossfade */
.cl-hero{position:relative;min-height:100vh;display:flex;align-items:center;overflow:hidden;padding:130px 46px 80px}
.cl-hero-media{position:absolute;inset:0;z-index:0}
.cl-hero-media img.cl-fallback,.cl-hero-media video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center}
.cl-hero-media img.cl-fallback{z-index:0}
