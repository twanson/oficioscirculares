<style>
/* ===================================================================
   CONECTA LANA — landing standalone
   Estilos 100% scoped bajo .cl-landing para aislarlos del CSS global
   (las clases .hero/.card/.cta/.nav/.step ya existen en el sitio).
   =================================================================== */
.cl-landing{
  --primary:#023429;--primary-2:#1F4B3F;--verde-hoja:#3E7C59;
  --secondary:#934a1c;--marron:#7d573c;--marron-2:#9a5530;--oro:#f6c98a;
  --crema:#fbf6ec;--arena:#E8D5B7;--surface:#fbf9f8;
