.cl-hero-media .cl-slide.on{opacity:1}
.cl-hero-grad{position:absolute;inset:0;z-index:2;background:linear-gradient(100deg,rgba(2,52,41,.84) 0%,rgba(2,52,41,.5) 30%,rgba(2,52,41,.14) 58%,rgba(2,52,41,0) 100%)}
.cl-hero-grad-b{position:absolute;inset:0;z-index:2;background:linear-gradient(0deg,rgba(2,52,41,.4) 0%,transparent 30%)}
@media(prefers-reduced-motion:reduce){.cl-hero-media video{display:none}.cl-hero-media .cl-slide{transition:none}}
.cl-hero-in{position:relative;z-index:10;max-width:820px}
.cl-kicker{display:inline-flex;align-items:center;gap:10px;padding:7px 16px 7px 8px;border-radius:100px;background:rgba(255,255,255,.14);backdrop-filter:blur(7px);-webkit-backdrop-filter:blur(7px);border:1px solid rgba(255,255,255,.18);margin-bottom:24px}
.cl-kicker img{height:24px;width:auto}
.cl-kicker span{color:#fff;font-weight:700;font-size:.7rem;letter-spacing:.15em;text-transform:uppercase}
.cl-hero h1{font-family:var(--f-head);font-size:clamp(3.6rem,9.5vw,7rem);font-weight:700;color:#fff;line-height:.96;letter-spacing:-.025em;margin-bottom:18px;text-shadow:0 3px 34px rgba(0,0,0,.4)}
.cl-hero h1 em{font-style:italic;font-weight:600;color:var(--oro)}
.cl-hero .cl-lead{font-family:var(--f-ui);font-size:clamp(1.3rem,2.2vw,1.72rem);font-weight:800;color:#fff;margin-bottom:14px;text-shadow:0 2px 16px rgba(0,0,0,.4)}
.cl-hero .cl-sub{color:rgba(255,255,255,.94);font-size:clamp(1.04rem,1.5vw,1.18rem);line-height:1.6;max-width:560px;margin-bottom:38px;text-shadow:0 2px 14px rgba(0,0,0,.42)}

/* CONECTOR: dos acciones unidas por un nudo central */
.cl-connector{display:inline-flex;align-items:stretch;position:relative;border-radius:100px;box-shadow:0 20px 48px rgba(0,0,0,.42)}
.cl-connector .cl-half{display:inline-flex;align-items:center;justify-content:center;gap:13px;min-width:252px;padding:21px 42px;color:#fff;font-family:var(--f-ui);font-weight:800;font-size:1.3rem;letter-spacing:.005em;transition:filter .22s ease,box-shadow .22s ease}
.cl-connector .cl-half .cl-ic{display:flex;flex:0 0 auto}
.cl-half--t{background:linear-gradient(135deg,#2f6151,#023429);border-radius:100px 0 0 100px;padding-right:54px}
.cl-half--b{background:linear-gradient(135deg,#b3683a,#7d3f1f);border-radius:0 100px 100px 0;padding-left:54px}
.cl-half--t:hover{filter:brightness(1.16);box-shadow:0 0 32px rgba(86,176,128,.65)}
.cl-half--b:hover{filter:brightness(1.13);box-shadow:0 0 32px rgba(219,134,78,.65)}
.cl-node{position:absolute;left:50%;top:50%;transform:translate(-50%,-50%);width:58px;height:58px;border-radius:50%;background:#fbf6ec;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 22px rgba(0,0,0,.4),0 0 0 6px rgba(251,246,236,.16);z-index:3}
.cl-hero .cl-micro{margin-top:18px;color:rgba(255,255,255,.78);font-size:.84rem;font-weight:600;letter-spacing:.02em;text-shadow:0 1px 8px rgba(0,0,0,.4)}

/* PUERTAS */
.cl-doors{padding:92px 46px;background:linear-gradient(165deg,#06241c 0%,#023429 60%,#06281f 100%)}
.cl-d-head{text-align:center;max-width:680px;margin:0 auto 50px}
.cl-d-head .cl-ey{color:var(--oro);font-weight:700;font-size:.76rem;letter-spacing:.16em;text-transform:uppercase}
.cl-d-head h2{font-family:var(--f-head);font-size:clamp(2rem,3.6vw,2.95rem);color:#fbf6ec;font-weight:700;line-height:1.12;margin:12px 0}
.cl-d-head h2 em{font-style:italic;color:var(--oro)}
.cl-d-head p{color:rgba(251,246,236,.74);font-size:1.06rem}
.cl-cards{display:grid;grid-template-columns:1fr 1fr;gap:24px;max-width:980px;margin:0 auto}
@media(max-width:780px){.cl-cards{grid-template-columns:1fr}}
.cl-card{background:linear-gradient(162deg,#fbf6ec 0%,#f0e4cf 100%);border-radius:22px;padding:38px 36px;display:flex;flex-direction:column;position:relative;overflow:hidden;box-shadow:0 18px 40px rgba(0,0,0,.3)}
.cl-card::before{content:"";position:absolute;top:0;left:0;right:0;height:5px}
.cl-card--t::before{background:linear-gradient(90deg,#1F4B3F,#3E7C59)}
.cl-card--b::before{background:linear-gradient(90deg,#9a5530,#c89177)}
.cl-card .cl-ico{width:58px;height:58px;border-radius:16px;display:flex;align-items:center;justify-content:center;margin-bottom:18px}
.cl-card--t .cl-ico{background:rgba(2,52,41,.08)}
.cl-card--b .cl-ico{background:rgba(154,85,48,.11)}
.cl-card h3{font-family:var(--f-head);font-size:1.9rem;font-weight:700;color:var(--primary);margin-bottom:8px}
.cl-card .cl-who{color:#5d5746;font-size:1.01rem;line-height:1.55;margin-bottom:20px}
.cl-chips{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.cl-chip{font-size:.78rem;font-weight:700;padding:5px 12px;border-radius:100px}
.cl-card--t .cl-chip{background:rgba(2,52,41,.08);color:#1F4B3F}
.cl-card--b .cl-chip{background:rgba(154,85,48,.1);color:#7d573c}
.cl-card .cl-cta{margin-top:auto;align-self:flex-start;display:inline-flex;align-items:center;gap:8px;padding:14px 28px;border-radius:100px;font-family:var(--f-ui);font-weight:800;font-size:1.02rem;transition:transform .25s ease,box-shadow .25s ease}
.cl-card--t .cl-cta{background:var(--primary);color:#f6ecd9}
.cl-card--t .cl-cta:hover{transform:translateX(3px);box-shadow:0 8px 22px rgba(2,52,41,.3)}
.cl-card--b .cl-cta{background:linear-gradient(135deg,#9a5530,#7d573c);color:#fdf6ec}
.cl-card--b .cl-cta:hover{transform:translateX(3px);box-shadow:0 8px 22px rgba(125,87,60,.35)}

/* CÓMO FUNCIONA */
.cl-how{padding:88px 46px;background:linear-gradient(180deg,#fbf9f8,#f3efe9)}
.cl-how .cl-d-head .cl-ey{color:var(--secondary)}
.cl-how .cl-d-head h2{color:var(--primary)}
.cl-how .cl-d-head h2 em{color:var(--secondary)}
.cl-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1000px;margin:0 auto;position:relative}
.cl-steps::before{content:'';position:absolute;top:62px;left:15%;right:15%;height:2px;background:repeating-linear-gradient(90deg,rgba(2,52,41,.22) 0 7px,transparent 7px 16px);z-index:0}
@media(max-width:780px){.cl-steps{grid-template-columns:1fr}.cl-steps::before{display:none}}
.cl-step{position:relative;z-index:1;background:linear-gradient(180deg,#ffffff,#fdfbf6);border:1px solid rgba(2,52,41,.07);border-radius:20px;padding:36px 28px 32px;text-align:center;box-shadow:0 12px 30px rgba(2,52,41,.07);transition:transform .25s ease,box-shadow .25s ease}
.cl-step:hover{transform:translateY(-5px);box-shadow:0 22px 46px rgba(2,52,41,.14)}
.cl-step .cl-num{width:62px;height:62px;border-radius:50%;margin:0 auto 14px;background:linear-gradient(140deg,#3E7C59,#023429);color:#f6c98a;font-family:var(--f-head);font-style:italic;font-size:1.75rem;display:flex;align-items:center;justify-content:center;box-shadow:0 8px 22px rgba(2,52,41,.3);border:5px solid #fbf9f8}
.cl-step .cl-pl{font-family:var(--f-ui);font-weight:800;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--secondary);margin-bottom:8px}
.cl-step h4{font-family:var(--f-ui);font-weight:800;font-size:1.26rem;color:var(--primary);margin-bottom:9px}
.cl-step p{color:var(--on-var);font-size:.98rem;line-height:1.55;max-width:240px;margin:0 auto}

/* CONFIANZA */
.cl-trust{padding:48px 46px;background:var(--primary);text-align:center}
.cl-trust img{height:56px;width:auto;margin-bottom:16px}
.cl-trust p{color:rgba(251,246,236,.9);max-width:680px;margin:0 auto;font-size:1.05rem}
.cl-trust strong{color:var(--oro)}

/* Logos claros sobre fondos oscuros */
.cl-nav .cl-brand img,.cl-kicker img,.cl-trust img{filter:drop-shadow(0 2px 9px rgba(0,0,0,.5))}

/* RESPONSIVE móvil */
@media(max-width:600px){
  .cl-nav{padding:16px 20px}
  .cl-hero{padding:104px 22px 60px}
  .cl-doors{padding:64px 22px}
  .cl-how{padding:62px 22px}
  .cl-trust{padding:42px 22px}
  .cl-connector{flex-direction:column;width:100%;max-width:340px;border-radius:24px}
  .cl-connector .cl-half{min-width:0;width:100%;font-size:1.18rem;padding:20px 24px}
  .cl-half--t{border-radius:24px 24px 0 0;padding-bottom:30px}
  .cl-half--b{border-radius:0 0 24px 24px;padding-top:30px}
  .cl-card{padding:30px 26px}
}

/* ============ EL PROBLEMA DE LA LANA (scrollytelling) ============ */
/* Clases renombradas vs. la maqueta para no colisionar con la propia
   página: cl-step→cl-why-step, cl-doors→cl-why-doors, cl-chips→cl-why-chips */
/* position:sticky se rompe si un ancestro es contenedor de scroll. El body
   global usa overflow-x:hidden; clip recorta el desbordamiento horizontal
   SIN crear contenedor de scroll, así el panel sticky vuelve a funcionar. */
html,body{overflow-x:clip}
.cl-why{position:relative}
.cl-sc{display:grid;grid-template-columns:1.18fr .82fr;background:linear-gradient(160deg,#06291f,#03201a)}
.cl-left{padding:0 4.6vw}
.cl-why-step{min-height:92vh;display:flex;flex-direction:column;justify-content:center;max-width:680px}
.cl-k{font-family:var(--f-ui);font-weight:800;font-size:.86rem;letter-spacing:.2em;text-transform:uppercase;color:var(--oro)}
.cl-big{font-family:var(--f-head);font-size:clamp(4.8rem,9vw,7.8rem);color:#fbf6ec;font-weight:600;line-height:.93;margin:16px 0 0;letter-spacing:-.026em}
.cl-why-step h3{font-family:var(--f-head);font-size:clamp(3.2rem,5.8vw,5rem);color:#fbf6ec;font-weight:600;line-height:1.01;margin:16px 0 0;letter-spacing:-.016em}
.cl-why-step h3 em{color:var(--oro);font-style:italic}
.cl-why-step p{color:rgba(251,246,236,.88);font-size:1.4rem;line-height:1.48;margin:20px 0 0}
.cl-viz{margin:36px 0 0;max-width:560px}
.cl-bar{margin:20px 0 0}
.cl-bar .cl-bl{display:flex;justify-content:space-between;align-items:baseline;font-size:.96rem;color:rgba(251,246,236,.76);margin-bottom:10px;font-weight:600}
.cl-bar .cl-bl b{color:var(--oro);font-size:1.12rem}
.cl-track{height:17px;border-radius:100px;background:rgba(251,246,236,.1);overflow:hidden}
.cl-fill{height:100%;border-radius:100px;background:linear-gradient(90deg,#f6c98a,#e0a965)}
.cl-fill.cl-dim{background:rgba(251,246,236,.26)}
.cl-note{font-size:1.02rem;color:rgba(251,246,236,.64);margin-top:15px;line-height:1.45}
.cl-why-chips{display:flex;gap:12px;flex-wrap:wrap;margin-top:22px}
.cl-why-chips span{font-size:.92rem;color:rgba(251,246,236,.88);background:rgba(246,201,138,.13);border:1px solid rgba(246,201,138,.28);padding:9px 16px;border-radius:100px;font-weight:600}
.cl-why-doors{display:flex;align-items:center;gap:16px;margin-top:32px;max-width:520px}
.cl-dm{flex:1;background:rgba(251,246,236,.05);border:1px solid rgba(246,201,138,.28);border-radius:16px;padding:18px 22px}
.cl-dm b{display:block;color:#fbf6ec;font-family:var(--f-ui);font-weight:800;font-size:1.2rem}
.cl-dm span{font-size:.9rem;color:rgba(251,246,236,.68)}
.cl-knot{color:var(--oro);font-size:1.9rem;font-weight:700}
.cl-right{position:relative}
.cl-sticky{position:sticky;top:0;height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden}
.cl-frame{position:absolute;width:78%;height:72%;border-radius:26px;overflow:hidden;box-shadow:0 44px 100px rgba(0,0,0,.55);opacity:0;transform:scale(1.05);transition:opacity .7s ease,transform 1s ease}
.cl-frame.cl-on{opacity:1;transform:scale(1)}
.cl-frame img{width:100%;height:100%;object-fit:cover}
.cl-cap{position:absolute;left:18px;bottom:18px;background:rgba(2,40,31,.62);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);color:#fbf6ec;font-family:var(--f-ui);font-weight:700;font-size:.9rem;padding:10px 16px;border-radius:100px;border:1px solid rgba(246,201,138,.32)}
.cl-prog{position:absolute;top:50%;right:26px;transform:translateY(-50%);display:flex;flex-direction:column;gap:11px;z-index:3}
.cl-prog i{width:8px;height:8px;border-radius:50%;background:rgba(246,201,138,.3);transition:.4s}
.cl-prog i.cl-on{background:var(--oro);transform:scale(1.5)}
.cl-why-mimg{display:none}
/* enlace-cue del hero hacia la sección */
.cl-landing .cl-why-link{display:inline-block;margin-top:22px;color:var(--oro);background:rgba(2,40,31,.62);backdrop-filter:blur(8px);-webkit-backdrop-filter:blur(8px);border:1px solid rgba(246,201,138,.42);border-radius:100px;padding:11px 20px;font-family:var(--f-ui);font-weight:700;font-size:.92rem;letter-spacing:.01em;transition:background .2s ease,border-color .2s ease,color .2s ease;text-shadow:0 1px 6px rgba(0,0,0,.45)}
.cl-landing .cl-why-link:hover{background:rgba(2,40,31,.8);border-color:var(--oro);color:#fff}
@media(max-width:760px){
  .cl-sc{grid-template-columns:1fr}
  .cl-right{display:none}
  .cl-left{padding:0 7vw}
  .cl-why-step{min-height:auto;padding:54px 0}
  .cl-big{font-size:clamp(3.4rem,13vw,4.6rem)}
  .cl-why-step h3{font-size:clamp(2.6rem,9vw,3.4rem)}
  .cl-why-step p{font-size:1.18rem}
  .cl-viz{margin-top:28px}
  .cl-why-mimg{display:block;position:relative;width:100%;border-radius:18px;overflow:hidden;margin:0 0 24px;box-shadow:0 22px 54px rgba(0,0,0,.5)}
  .cl-why-mimg img{width:100%;height:230px;object-fit:cover;display:block}
}
</style>

