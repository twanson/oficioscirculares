<script>
/* Crossfade del hero: hero-a → hero-b → hero-c → (loop). Respeta prefers-reduced-motion. */
(function(){
  var S=[].slice.call(document.querySelectorAll('.cl-hero-media .cl-slide'));
  if(!S.length) return;
  var mq=window.matchMedia('(prefers-reduced-motion: reduce)');
  if(mq.matches) return; /* sin movimiento: se queda el póster */
  var XF=1.1; /* segundos de solape del crossfade */
  function play(v){try{v.currentTime=0;var p=v.play();if(p&&p.catch){p.catch(function(){});}}catch(e){}}
  function act(i){S.forEach(function(v,k){v.classList.toggle('on',k===i);});}
  function watch(i){
    var v=S[i];
    function t(){
      if(v.duration && v.currentTime>=v.duration-XF){
        v.removeEventListener('timeupdate',t);
        var n=(i+1)%S.length;
        act(n); play(S[n]); watch(n);
        setTimeout(function(){v.pause();}, XF*1000+60);
      }
    }
    v.addEventListener('timeupdate',t);
  }
  act(0); play(S[0]); watch(0);
})();

/* Scrollytelling "El problema de la lana": IntersectionObserver activa la
   imagen + el punto de progreso del paso centrado en el viewport. */
(function(){
  var steps=[].slice.call(document.querySelectorAll('.cl-why-step'));
  if(!steps.length) return;
  var frames=[].slice.call(document.querySelectorAll('.cl-frame'));
  var dots=[].slice.call(document.querySelectorAll('.cl-prog i'));
  function setA(i){
    frames.forEach(function(f){f.classList.toggle('cl-on',f.dataset.i===i);});
    dots.forEach(function(d){d.classList.toggle('cl-on',d.dataset.p===i);});
  }
  var io=new IntersectionObserver(function(es){
    es.forEach(function(e){ if(e.isIntersecting) setA(e.target.dataset.i); });
  },{rootMargin:'-45% 0px -45% 0px'});
  steps.forEach(function(s){io.observe(s);});
})();
</script>
