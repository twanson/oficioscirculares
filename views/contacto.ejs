<%- include('partials/head-meta', {
    title: 'Hablemos de tu proyecto | Oficios Circulares',
    description: 'Cuéntanos qué tienes en mente. Te proponemos un primer paso claro para tu proyecto artesanal o circular.',
    canonical: '/contacto',
    ogImage: 'https://www.oficioscirculares.com/img/general/og-contacto.webp',
    ogImageAlt: 'Contacto Oficios Circulares — Hablemos de tu proyecto'
}) %>
<%- include('partials/header') %>

<main class="main-content page-contacto" id="maincontent">
    <section class="contacto-section" aria-labelledby="contacto-title">
        <div class="container">
            <div class="contacto-header">
                <span class="contacto-label">Contacto</span>
                <h1 id="contacto-title" class="contacto-title">Hablemos de tu proyecto</h1>
                <p class="contacto-subtitle">Cuéntanos qué tienes en mente y te proponemos un primer paso claro.</p>
            </div>
            
            <!-- Selector de servicio si no hay service en query params -->
            <div id="service-selector" class="service-selector" style="display: none;">
                <div class="selector-content">
                    <h2 class="selector-title">¿Sobre qué te gustaría hablar?</h2>
                    <div class="selector-buttons">
                        <a href="/contacto?service=diagnostico-3d" 
                           class="btn btn-outline"
                           data-event="click_cta" 
                           data-label="contacto-selector-diag3d">
                            Diagnóstico 3D
                        </a>
                        <a href="/contacto?service=roadmap-3d" 
                           class="btn btn-outline"
                           data-event="click_cta" 
                           data-label="contacto-selector-roadmap3d">
                            Roadmap 3D
                        </a>
                        <a href="/contacto?service=sprint-3d" 
                           class="btn btn-outline"
                           data-event="click_cta" 
                           data-label="contacto-selector-sprint3d">
                            Sprint 3D
                        </a>
                    </div>
                </div>
            </div>

            <!-- Contenedor del iframe de Tally -->
            <div class="tally-container">
                <iframe
                    id="tally-iframe"
                    src=""
                    data-tally-src=""
                    width="100%"
                    height="900"
                    frameborder="0"
                    title="Contacto — Servicios 3D"
                    style="background: transparent; min-height: 600px;"
                    loading="lazy">
                </iframe>
            </div>
        </div>
    </section>
</main>

<style>
/* Estilos página de contacto — v2 alineado con Impulso 3D */
.page-contacto {
    background: var(--surface, #fbf9f8);
    min-height: 100vh;
}

.contacto-section {
    padding: 100px 0 80px;
}

.contacto-section .container {
    max-width: 720px;
    margin: 0 auto;
    padding: 0 24px;
}

.contacto-header {
    text-align: center;
    margin-bottom: 48px;
}

.contacto-label {
    display: inline-block;
    font-family: var(--font-body, 'Manrope', sans-serif);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--secondary, #934a1c);
    margin-bottom: 12px;
}

.contacto-title {
    font-family: var(--font-headline, 'Newsreader', serif);
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    color: var(--primary, #023429);
    margin-bottom: 16px;
    line-height: 1.15;
}

.contacto-subtitle {
    font-family: var(--font-body, 'Manrope', sans-serif);
    font-size: 1.1rem;
    color: var(--primary, #023429);
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.6;
    opacity: 0.75;
}

.service-selector {
    background: white;
    border: none;
    border-radius: 16px;
    padding: 36px 32px;
    margin-bottom: 32px;
    text-align: center;
    box-shadow: 0 4px 24px rgba(31, 75, 63, 0.08);
}

.selector-title {
    font-family: var(--font-headline, 'Newsreader', serif);
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--primary, #023429);
    margin-bottom: 24px;
}

.selector-buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
}

.selector-buttons .btn {
    min-width: 160px;
    font-family: var(--font-body, 'Manrope', sans-serif);
}

.tally-container {
    background: var(--surface, #fbf9f8);
    border: 1px solid rgba(31, 75, 63, 0.08);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 24px rgba(31, 75, 63, 0.06);
    min-height: 600px;
    padding: 0;
}

.tally-container iframe {
    display: block;
    width: 100%;
    border: none;
    background: transparent;
}

.tally-container iframe[data-tally-src] {
    border-radius: 16px;
}

/* Responsive */
@media (max-width: 768px) {
    .contacto-section {
        padding: 80px 0 60px;
    }

    .service-selector {
        padding: 28px 20px;
        margin-bottom: 24px;
    }

    .selector-buttons {
        flex-direction: column;
        align-items: center;
    }

    .selector-buttons .btn {
        width: 100%;
        max-width: 280px;
    }

    .tally-container iframe {
        height: 800px;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // Obtener parámetros de la URL
    const urlParams = new URLSearchParams(window.location.search);
    const service = urlParams.get('service');
    
    // Elementos del DOM
    const serviceSelector = document.getElementById('service-selector');
    const tallyIframe = document.getElementById('tally-iframe');
    
    // Si no hay servicio, mostrar selector
    if (!service) {
        serviceSelector.style.display = 'block';
        tallyIframe.style.display = 'none';
        return;
    }
    
    // Construir URL del iframe de Tally
    const tallyBaseUrl = 'https://tally.so/r/w4Zy5d';
    const tallyParams = new URLSearchParams({
        transparentBackground: '1',
        dynamicHeight: '1',
        hideTitle: '1',
        service: urlParams.get('service') || '',
        utm_source: urlParams.get('utm_source') || '',
        utm_medium: urlParams.get('utm_medium') || '',
        utm_campaign: urlParams.get('utm_campaign') || '',
        utm_content: urlParams.get('utm_content') || '',
        page_path: urlParams.get('page_path') || '',
    });
    
    const tallySrc = `${tallyBaseUrl}?${tallyParams.toString()}`;
    
    // Configurar iframe
    tallyIframe.src = tallySrc;
    tallyIframe.setAttribute('data-tally-src', tallySrc);
    
    // Ocultar selector si hay servicio
    serviceSelector.style.display = 'none';
    tallyIframe.style.display = 'block';
    
    console.log('📝 Tally form loaded with params:', Object.fromEntries(tallyParams));
});
</script>

<!-- Cargar script de Tally para funcionalidades avanzadas -->
<script async src="https://tally.so/widgets/embed.js"></script>

<!-- Script principal para funcionalidad del header -->
<script src="/assets/js/script.js"></script>

<%- include('partials/footer') %>
