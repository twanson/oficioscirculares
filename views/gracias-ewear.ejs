<script>
// Función para descargar documentos E-WEAR
function downloadEwearDocs() {
    // Tracking GTM/GA4 para descargas
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
        event: 'file_download',
        file_name: 'e-wear-docs-bundle',
        resource_title: 'Documentos E-WEAR',
        download_type: 'case_study_bundle',
        page_location: window.location.href
    });
    
    console.log('🔥 Iniciando descargas E-WEAR');
    
    // Descarga 1: Ficha de lote
    const link1 = document.createElement('a');
    link1.href = '/assets/docs/cases/e-wear/ficha_lote_oficios_circulares_web.pdf';
    link1.download = 'ficha_lote_oficios_circulares_web.pdf';
    link1.style.display = 'none';
    document.body.appendChild(link1);
    link1.click();
    document.body.removeChild(link1);
    console.log('📥 Descarga 1: Ficha de lote');
    
    // Descarga 2: Checklist con delay
    setTimeout(() => {
        const link2 = document.createElement('a');
        link2.href = '/assets/docs/cases/e-wear/checklist_trazabilidad_oficios_circulares_web.pdf';
        link2.download = 'checklist_trazabilidad_oficios_circulares_web.pdf';
        link2.style.display = 'none';
        document.body.appendChild(link2);
        link2.click();
        document.body.removeChild(link2);
        console.log('📋 Descarga 2: Checklist');
    }, 1000);
}
</script>

